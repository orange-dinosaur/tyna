{
    "name": "tyna",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "format": "prettier --write \"**/*.{js,mjs,ts,tsx,md,json,css}\"",
        "check-types": "turbo run check-types",
        "mobile:dev": "pnpm --filter mobile web",
        "web:dev": "pnpm --filter web dev"
    },
    "devDependencies": {
        "@workspace/eslint-config": "workspace:*",
        "@workspace/typescript-config": "workspace:*",
        "prettier": "^3.6.2",
        "turbo": "^2.5.5",
        "typescript": "5.7.3"
    },
    "packageManager": "pnpm@10.24.0",
    "engines": {
        "node": ">=20"
    }
}
